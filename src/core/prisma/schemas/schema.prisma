generator client {
  provider        = "prisma-client"
  output          = "../generated"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model AuthUsers {
  instance_id                 String?                @db.Uuid
  id                          String                 @id @db.Uuid
  role                        String?                @db.VarChar(255)
  email                       String?                @unique(map: "users_email_partial_key", where: raw("(is_sso_user = false)")) @db.VarChar(255)
  is_anonymous                Boolean                @default(false)
  // users                       public_users?

  @@index([instance_id])
  @@index([is_anonymous])
  @@map("users")
  @@schema("auth")
  @@ignore
}

model Subscriptions {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  title             String
  description       String
  price             Decimal   @db.Decimal(6, 2)
  paymentInterval   String    @map("payment_interval")
  paymentDate       DateTime  @map("payment_date") @db.Date
  status            String
  nextBillingDate   DateTime? @map("next_billing_date") @db.Date
  createdAt         DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)

  @@index([description(ops: raw("gin_trgm_ops"))], map: "idx_subscriptions_description_trgm", type: Gin)
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_subscriptions_title_trgm", type: Gin)
  @@schema("public")
}

model Users {
  id         String     @id @db.Uuid
  firstName  String?    @map("first_name")
  lastName   String?    @map("last_name")
  avatarUrl  String?    @map("avatar_url")
  roles      String[]   @default(["user"])
  createdAt  DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)
  // users      AuthUsers @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("users")
  @@schema("public")
}